@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Delete Venue";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body p-4">
                <h5 class="card-title">Are you sure you want to delete this venue?</h5>
                @if (Model.Bookings.Any() || Model.Events.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        This venue cannot be deleted because it has
                        @if (Model.Events.Any())
                        {
                            <strong>@Model.Events.Count event(s)</strong>
                        }
                        @if (Model.Bookings.Any())
                        {
                            <text> and <strong>@Model.Bookings.Count booking(s)</strong></text>
                        }
                        associated with it.
                    </div>
                }
                <dl class="row mt-3">
                    <dt class="col-sm-4">Venue Name</dt>
                    <dd class="col-sm-8">@Model.VenueName</dd>
                    <dt class="col-sm-4">Location</dt>
                    <dd class="col-sm-8">@Model.Location</dd>
                    <dt class="col-sm-4">Capacity</dt>
                    <dd class="col-sm-8">@Model.Capacity.ToString("N0")</dd>
                </dl>
                <div class="d-flex gap-2 mt-4">
                    @if (!Model.Bookings.Any() && !Model.Events.Any())
                    {
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="VenueId" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                        </form>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>