@model EventEase.Models.Venue
@{
    ViewData["Title"] = Model.VenueName;
}

<div class="row">
    <div class="col-md-5">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.VenueName"
                 onerror="this.src='https://via.placeholder.com/600x400?text=No+Image'" />
        }
    </div>
    <div class="col-md-7">
        <h2 class="fw-bold mb-1" style="color: var(--primary);">@Model.VenueName</h2>
        <hr />
        <dl class="row">
            <dt class="col-sm-4"><i class="bi bi-geo-alt me-1"></i>Location</dt>
            <dd class="col-sm-8">@Model.Location</dd>
            <dt class="col-sm-4"><i class="bi bi-people me-1"></i>Capacity</dt>
            <dd class="col-sm-8">@Model.Capacity.ToString("N0") guests</dd>
            <dt class="col-sm-4"><i class="bi bi-calendar3 me-1"></i>Events</dt>
            <dd class="col-sm-8">@Model.Events.Count event(s) scheduled</dd>
            <dt class="col-sm-4"><i class="bi bi-journal-check me-1"></i>Bookings</dt>
            <dd class="col-sm-8">@Model.Bookings.Count booking(s)</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Venues
            </a>
        </div>
    </div>
</div>
