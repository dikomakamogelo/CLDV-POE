@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Add Venue";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-building-add me-2"></i>Add New Venue</div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="mb-3">
                        <label asp-for="VenueName" class="form-label fw-semibold"></label>
                        <input asp-for="VenueName" class="form-control" placeholder="e.g. The Grand Hall" />
                        <span asp-validation-for="VenueName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold"></label>
                        <input asp-for="Location" class="form-control" placeholder="e.g. 123 Main Street, Johannesburg" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold"></label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        <div class="form-text">Provide a URL to an image for this venue.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Save Venue
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
