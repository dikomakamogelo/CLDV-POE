@model IEnumerable<EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary);">
        <i class="bi bi-building me-2"></i>Venues
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add New Venue
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No venues found. <a asp-action="Create">Add your first venue.</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var venue in Model)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(venue.ImageUrl))
                    {
                        <img src="@venue.ImageUrl" class="card-img-top" alt="@venue.VenueName"
                             style="height: 180px; object-fit: cover; border-radius: 10px 10px 0 0;"
                             onerror="this.src='https://via.placeholder.com/400x180?text=No+Image'" />
                    }
                    <div class="card-body">
                        <h5 class="card-title fw-bold">@venue.VenueName</h5>
                        <p class="text-muted mb-1"><i class="bi bi-geo-alt me-1"></i>@venue.Location</p>
                        <p class="text-muted"><i class="bi bi-people me-1"></i>Capacity: <strong>@venue.Capacity.ToString("N0")</strong></p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}