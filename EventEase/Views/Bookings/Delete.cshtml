@model EventEase.Models.Booking
@{
    ViewData["Title"] = "Delete Booking";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body p-4">
                <h5 class="card-title">Are you sure you want to delete this booking?</h5>
                <p class="text-muted">This action cannot be undone.</p>
                <dl class="row mt-3">
                    <dt class="col-sm-4">Booking Reference</dt>
                    <dd class="col-sm-8">@Model.BookingReference</dd>
                    <dt class="col-sm-4">Customer</dt>
                    <dd class="col-sm-8">@Model.CustomerName</dd>
                    <dt class="col-sm-4">Event</dt>
                    <dd class="col-sm-8">@Model.Event?.EventName</dd>
                    <dt class="col-sm-4">Venue</dt>
                    <dd class="col-sm-8">@Model.Venue?.VenueName</dd>
                    <dt class="col-sm-4">Booking Date</dt>
                    <dd class="col-sm-8">@Model.BookingDate.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
                <div class="d-flex gap-2 mt-4">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="BookingId" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i>Yes, Delete
                        </button>
                    </form>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
