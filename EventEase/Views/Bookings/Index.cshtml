@model IEnumerable<EventEase.Models.Booking>
@{
    ViewData["Title"] = "Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary);">
        <i class="bi bi-journal-check me-2"></i>Bookings
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>New Booking
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No bookings found. <a asp-action="Create">Create your first booking.</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Booking Ref</th>
                    <th>Customer</th>
                    <th>Event</th>
                    <th>Venue</th>
                    <th>Booking Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td><span class="badge bg-secondary">@booking.BookingReference</span></td>
                        <td>
                            <div class="fw-semibold">@booking.CustomerName</div>
                            <small class="text-muted">@booking.CustomerEmail</small>
                        </td>
                        <td>@booking.Event?.EventName</td>
                        <td>@booking.Venue?.VenueName</td>
                        <td>@booking.BookingDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}