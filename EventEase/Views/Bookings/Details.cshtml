@model EventEase.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-journal-check me-2"></i>Booking Details</span>
                <span class="badge bg-light text-dark">@Model.BookingReference</span>
            </div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-sm-4">Booking Reference</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary fs-6">@Model.BookingReference</span></dd>
                    <dt class="col-sm-4">Customer Name</dt>
                    <dd class="col-sm-8">@Model.CustomerName</dd>
                    <dt class="col-sm-4">Customer Email</dt>
                    <dd class="col-sm-8">@Model.CustomerEmail</dd>
                    <dt class="col-sm-4">Event</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Events" asp-action="Details" asp-route-id="@Model.EventId">
                            @Model.Event?.EventName
                        </a>
                    </dd>
                    <dt class="col-sm-4">Venue</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId">
                            @Model.Venue?.VenueName
                        </a>
                    </dd>
                    <dt class="col-sm-4">Booking Date</dt>
                    <dd class="col-sm-8">@Model.BookingDate.ToString("dddd, dd MMMM yyyy HH:mm")</dd>
                </dl>
                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to Bookings
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
