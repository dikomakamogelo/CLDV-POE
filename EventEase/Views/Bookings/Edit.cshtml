@model EventEase.Models.Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header"><i class="bi bi-journal-text me-2"></i>Edit Booking</div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="BookingId" />
                    <input type="hidden" asp-for="BookingReference" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Booking Reference</label>
                        <input value="@Model.BookingReference" class="form-control" readonly />
                    </div>
                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerName" class="form-control" />
                        <span asp-validation-for="CustomerName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CustomerEmail" class="form-label fw-semibold"></label>
                        <input asp-for="CustomerEmail" class="form-control" type="email" />
                        <span asp-validation-for="CustomerEmail" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="EventId" class="form-label fw-semibold"></label>
                        <select asp-for="EventId" class="form-select" asp-items="ViewBag.EventId">
                            <option value="">-- Select an Event --</option>
                        </select>
                        <span asp-validation-for="EventId" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="VenueId" class="form-label fw-semibold"></label>
                        <select asp-for="VenueId" class="form-select" asp-items="ViewBag.VenueId">
                            <option value="">-- Select a Venue --</option>
                        </select>
                        <span asp-validation-for="VenueId" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="BookingDate" class="form-label fw-semibold"></label>
                        <input asp-for="BookingDate" class="form-control" type="datetime-local" />
                        <span asp-validation-for="BookingDate" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-1"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
