@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold" style="color: var(--primary);">
            <i class="bi bi-speedometer2 me-2"></i>EventEase Dashboard
        </h2>
        <p class="text-muted">Welcome to the EventEase Venue Booking Management System.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card text-white h-100" style="background: linear-gradient(135deg, #1a3a5c, #2a5a8c);">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-building fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.VenueCount</div>
                    <div class="text-white-50">Total Venues</div>
                </div>
            </div>
            <div class="card-footer border-0 bg-transparent">
                <a asp-controller="Venues" asp-action="Index" class="text-white text-decoration-none small">
                    View all venues <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white h-100" style="background: linear-gradient(135deg, #e8a020, #d4870e);">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-calendar3 fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.EventCount</div>
                    <div class="text-white-50">Total Events</div>
                </div>
            </div>
            <div class="card-footer border-0 bg-transparent">
                <a asp-controller="Events" asp-action="Index" class="text-white text-decoration-none small">
                    View all events <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white h-100" style="background: linear-gradient(135deg, #198754, #0f6b40);">
            <div class="card-body d-flex align-items-center">
                <i class="bi bi-journal-check fs-1 me-3 opacity-75"></i>
                <div>
                    <div class="fs-1 fw-bold">@ViewBag.BookingCount</div>
                    <div class="text-white-50">Total Bookings</div>
                </div>
            </div>
            <div class="card-footer border-0 bg-transparent">
                <a asp-controller="Bookings" asp-action="Index" class="text-white text-decoration-none small">
                    View all bookings <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-building me-2"></i>Manage Venues</div>
            <div class="card-body">
                <p class="card-text text-muted">Add, edit, or remove event venues. Each venue has a name, location, capacity, and image.</p>
                <a asp-controller="Venues" asp-action="Create" class="btn btn-primary me-2">
                    <i class="bi bi-plus-circle me-1"></i>Add Venue
                </a>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-outline-secondary">View All</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-calendar3 me-2"></i>Manage Events</div>
            <div class="card-body">
                <p class="card-text text-muted">Schedule and manage events. Link events to venues with start and end dates.</p>
                <a asp-controller="Events" asp-action="Create" class="btn btn-primary me-2">
                    <i class="bi bi-plus-circle me-1"></i>Add Event
                </a>
                <a asp-controller="Events" asp-action="Index" class="btn btn-outline-secondary">View All</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><i class="bi bi-journal-check me-2"></i>Manage Bookings</div>
            <div class="card-body">
                <p class="card-text text-muted">Create and track bookings for events. The system prevents double bookings automatically.</p>
                <a asp-controller="Bookings" asp-action="Create" class="btn btn-primary me-2">
                    <i class="bi bi-plus-circle me-1"></i>New Booking
                </a>
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-outline-secondary">View All</a>
            </div>
        </div>
    </div>
</div>
