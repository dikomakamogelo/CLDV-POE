@model EventEase.Models.Event
@{
    ViewData["Title"] = Model.EventName;
}

<div class="row">
    <div class="col-md-5">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.EventName"
                 onerror="this.src='https://via.placeholder.com/600x400?text=No+Image'" />
        }
    </div>
    <div class="col-md-7">
        <h2 class="fw-bold mb-1" style="color: var(--primary);">@Model.EventName</h2>
        <p class="text-muted">@Model.Description</p>
        <hr />
        <dl class="row">
            <dt class="col-sm-4"><i class="bi bi-building me-1"></i>Venue</dt>
            <dd class="col-sm-8">
                <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId">
                    @Model.Venue?.VenueName
                </a>
            </dd>
            <dt class="col-sm-4"><i class="bi bi-calendar-event me-1"></i>Start Date</dt>
            <dd class="col-sm-8">@Model.StartDate.ToString("dddd, dd MMMM yyyy HH:mm")</dd>
            <dt class="col-sm-4"><i class="bi bi-calendar-x me-1"></i>End Date</dt>
            <dd class="col-sm-8">@Model.EndDate.ToString("dddd, dd MMMM yyyy HH:mm")</dd>
            <dt class="col-sm-4"><i class="bi bi-journal-check me-1"></i>Bookings</dt>
            <dd class="col-sm-8">@Model.Bookings.Count booking(s)</dd>
        </dl>
        <div class="d-flex gap-2 mt-3">
            <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Events
            </a>
        </div>
    </div>
</div>
