@model IEnumerable<EventEase.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary);">
        <i class="bi bi-calendar3 me-2"></i>Events
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Add New Event
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No events found. <a asp-action="Create">Schedule your first event.</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Venue</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                @if (!string.IsNullOrEmpty(evt.ImageUrl))
                                {
                                    <img src="@evt.ImageUrl" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:6px;"
                                         onerror="this.style.display='none'" />
                                }
                                <div>
                                    <div class="fw-semibold">@evt.EventName</div>
                                    <small class="text-muted">@(evt.Description.Length > 60 ? evt.Description[..60] + "..." : evt.Description)</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-primary">@evt.Venue?.VenueName</span></td>
                        <td>@evt.StartDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@evt.EndDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Details" asp-route-id="@evt.EventId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@evt.EventId" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@evt.EventId" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
