@model EventEase.Models.Event
@{
    ViewData["Title"] = "Delete Event";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete
            </div>
            <div class="card-body p-4">
                <h5 class="card-title">Are you sure you want to delete this event?</h5>
                @if (Model.Bookings.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        This event cannot be deleted because it has <strong>@Model.Bookings.Count booking(s)</strong> associated with it.
                    </div>
                }
                <dl class="row mt-3">
                    <dt class="col-sm-4">Event Name</dt>
                    <dd class="col-sm-8">@Model.EventName</dd>
                    <dt class="col-sm-4">Venue</dt>
                    <dd class="col-sm-8">@Model.Venue?.VenueName</dd>
                    <dt class="col-sm-4">Start Date</dt>
                    <dd class="col-sm-8">@Model.StartDate.ToString("dd MMM yyyy HH:mm")</dd>
                    <dt class="col-sm-4">End Date</dt>
                    <dd class="col-sm-8">@Model.EndDate.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
                <div class="d-flex gap-2 mt-4">
                    @if (!Model.Bookings.Any())
                    {
                        <form asp-action="Delete">
                            <input type="hidden" asp-for="EventId" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>Yes, Delete
                            </button>
                        </form>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Cancel
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
